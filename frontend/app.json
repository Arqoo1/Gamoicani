{
  "expo": {
    "name": "გამოიცანი",
    "slug": "gamoicani",
    "scheme": "gamoicani",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "icon": "./assets/logoicon.png",
    "splash": {
      "image": "./assets/splashimg.png",
      "resizeMode": "contain",
      "backgroundColor": "#2f9e5d"
    },
    "plugins": [
      "expo-router",
      "expo-status-bar",
      "expo-audio",
      "expo-notifications",
      "@react-native-google-signin/google-signin"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.gamoicani"
    },
    "android": {
      "package": "com.gamoicani",
      "adaptiveIcon": {
        "foregroundImage": "./assets/logoicon.png",
        "backgroundColor": "#2f9e5d"
      },
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "bundler": "metro"
    }
  }
}
